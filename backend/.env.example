# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://psz_user:password@db:5432/polacyszwajcaria
DATABASE_URL_SYNC=postgresql://psz_user:password@db:5432/polacyszwajcaria
REDIS_URL=redis://redis:6379/0

# JWT Authentication
JWT_SECRET=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# File uploads
UPLOAD_DIR=./uploads
MAX_CV_SIZE_MB=5
MAX_LOGO_SIZE_MB=2

# Email (Resend - https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=PolacySzwajcaria <noreply@polacyszwajcaria.ch>
EMAIL_ENABLED=false

# reCAPTCHA v3
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_ENABLED=false
RECAPTCHA_SCORE_THRESHOLD=0.5

# Frontend URL (for email links)
FRONTEND_URL=https://polacyszwajcaria.ch

# Admin (first admin user created on startup)
FIRST_ADMIN_EMAIL=admin@polacyszwajcaria.ch
FIRST_ADMIN_PASSWORD=change-me-on-first-login
