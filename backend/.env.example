# =====================================================================
# Production checklist:
# - JWT_SECRET: wygeneruj 64-byte random (python -c "import secrets; print(secrets.token_urlsafe(64))")
# - RECAPTCHA_ENABLED=true + prawdziwe klucze
# - EMAIL_ENABLED=true + RESEND_API_KEY
# - ENVIRONMENT=production (wylacza localhost CORS)
# - FRONTEND_URL = pelny URL produkcyjny
# =====================================================================

# Environment (development | production)
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://psz_user:password@db:5432/polacyszwajcaria
DATABASE_URL_SYNC=postgresql://psz_user:password@db:5432/polacyszwajcaria
REDIS_URL=redis://redis:6379/0

# JWT Authentication
JWT_SECRET=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# File uploads
UPLOAD_DIR=./uploads
MAX_CV_SIZE_MB=5
MAX_LOGO_SIZE_MB=2

# Email (Resend - https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Praca w Szwajcarii <noreply@praca-w-szwajcarii.ch>
EMAIL_ENABLED=false
# Test mode dla aplikacji external — gdy ustawione, maile ida na ten adres zamiast do pracodawcy
APPLICATION_TEST_RECIPIENT=

# reCAPTCHA v3 (WYMAGANE w produkcji)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_ENABLED=false
RECAPTCHA_SCORE_THRESHOLD=0.5

# Rate limiter (wylacz tylko w testach)
RATELIMIT_ENABLED=true

# CORS — dodatkowe origins poza FRONTEND_URL, comma-separated
ALLOWED_ORIGINS=

# Frontend URL (dla emaili i CORS)
FRONTEND_URL=https://praca-w-szwajcarii.ch

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Backend public URL (dla OAuth redirect_uri)
OAUTH_REDIRECT_BASE_URL=https://api.praca-w-szwajcarii.ch

# Admin (first admin user created on startup)
FIRST_ADMIN_EMAIL=admin@praca-w-szwajcarii.ch
FIRST_ADMIN_PASSWORD=change-me-on-first-login

# OpenAI (AI translation/extraction)
OPENAI_API_KEY=
